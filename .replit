modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dev Proxy 3000"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8099 pnpm --filter @workspace/api-server run dev:app"
waitForPort = 8099

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/aidea-creative run dev:app"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Dev Proxy 3000"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PROXY_PORT=3000 TARGET_PORT=5000 node scripts/dev-proxy.mjs"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8099
externalPort = 8099

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_MIDTRANS_CLIENT_KEY = "Mid-client-mtXT-6umS02pM65w"
PORT = "5000"
BASE_PATH = "/"
NODE_ENV = "development"
UPLOAD_DIR = "/home/runner/workspace/uploads"
AI_MODEL = "gpt-4o-mini"
